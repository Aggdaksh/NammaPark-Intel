{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/.next",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/login",
      "destination": "/api/login"
    },
    {
      "source": "/api/session",
      "destination": "/api/session"
    },
    {
      "source": "/api/commander",
      "destination": "/api/commander"
    },
    {
      "source": "/api/:path*",
      "destination": "https://nammapark-intel.onrender.com/api/:path*"
    }
  ]
}
